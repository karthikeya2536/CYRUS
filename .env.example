# =============================================================================
# CYRUS V2 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# FRONTEND (VITE_*): baked at build time, exposed to the browser.
#   The file .env is loaded by Vite at dev/build time.
#
# EDGE FUNCTION SECRETS: set via `supabase secrets set KEY=value`.
#   These are never placed in .env. Instead, set them directly on the
//   Supabase project with the supabase CLI or the Dashboard.
#
# VAULT SECRETS: stored in the Supabase Vault extension (encrypted at rest).
#   These are used by pg_cron scheduled jobs that need secrets at runtime.
//   Create them with:  SELECT vault.create_secret('value', 'name');
// =============================================================================

# --- Frontend (Vite) ---------------------------------------------------------
VITE_SUPABASE_URL=https://qdtyxwmejvyxqgtpibqn.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFkdHl4d21lanZ5eHFndHBpYnFuIiwicm9sZSI6ImFub24iLCJpYXIiOjE3ODA2MzgxMjIsImV4cCI6MjA5NjIxNDEyMn0.Gyk6YLjKSJLGd5Lv8DWCdHF9EiCV3zSXDlkfbGKxFnw
VITE_GOOGLE_CLIENT_ID=168258602058-qcqgfkns23pfdch8bv2brue6e8bpdhok.apps.googleusercontent.com
VITE_SLACK_CLIENT_ID=your_slack_oauth_client_id_here
VITE_NOTION_CLIENT_ID=your_notion_oauth_client_id_here

# --- Edge Function Secrets (set via `supabase secrets set`) -------------------
# These are listed here for documentation only. Do NOT put real values in .env.
# Use the supabase CLI or Dashboard to set them:
#
#   ALLOWED_ORIGIN            | 4e90ec8f9d9b8d5bd3877ac003797738ff48419fcf8f97821a875ea4671955b6
#
#   supabase secrets set OMNIROUTE_BASE_URL=...
#   supabase secrets set OMNIROUTE_API_KEY=...
#   supabase secrets set OMNIROUTE_DEFAULT_MODEL=...
#   supabase secrets set OMNIROUTE_EMBEDDING_MODEL=...
#   supabase secrets set OMNIROUTE_TIMEOUT=...
#   For local development: supabase secrets set ALLOWED_ORIGIN=http://localhost:5173
#   For production: supabase secrets set ALLOWED_ORIGIN=https://your-app-domain.com
#   For multiple origins (comma-separated): supabase secrets set ALLOWED_ORIGIN=http://localhost:5173,https://your-app-domain.com
#   supabase secrets set SLACK_CLIENT_SECRET=...
#   supabase secrets set NOTION_CLIENT_SECRET=...
#   supabase secrets set STRIPE_SECRET_KEY=...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=...
#   supabase secrets set STRIPE_PRICE_PRO=price_pro...
#   supabase secrets set STRIPE_PRICE_BUSINESS=price_business...
#   supabase secrets set STRIPE_PRICE_ENTERPRISE=price_enterprise...
#
# WORKER_SECRET: Shared secret used by pg_cron to authenticate with the
#   llm-worker edge function. Generate with: openssl rand -hex 16
#   This value MUST also be stored in Vault as 'worker_secret' so pg_cron
#   can pass it in the x-worker-secret header.
WORKER_SECRET=

# --- Vault Secrets (create via Supabase SQL editor) --------------------------
# These are NOT environment variables. Create them with SQL:
#
#   SELECT vault.create_secret('https://<REF>.supabase.co', 'project_url');
#   SELECT vault.create_secret('<same-value-as-WORKER_SECRET>', 'worker_secret');